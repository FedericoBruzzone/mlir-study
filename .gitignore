.venv/
__pycache__/
*.pyc
*.pyo

# ── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?

# ── Compiled binaries & intermediate files ──────────────────────────────────
*.o
*.a
*.dylib
